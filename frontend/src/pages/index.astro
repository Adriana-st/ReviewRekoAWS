---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <div class="min-h-screen bg-slate-50">
    <div class="max-w-2xl mx-auto px-4 py-10">

      <!-- ── Header ─────────────────────────────────────────── -->
      <div class="mb-4">
        <h1 class="text-2xl font-semibold tracking-tight text-slate-900">ReviewReko</h1>
        <p class="mt-1 text-sm text-slate-400">Smart review moderation · AWS Rekognition</p>
      </div>

      <!-- ── Nav ───────────────────────────────────────────── -->
      <nav class="flex border-b border-slate-200 mb-2">
        <a id="nav-submit"  class="nav-tab active">Submit Review</a>
        <a id="nav-gallery" class="nav-tab">Browse Reviews</a>
        <!-- <a id="nav-admin"   class="nav-tab">Admin</a> -->
      </nav>

      <hr class="border-slate-200 mb-6" />

      <!-- ══════════════ SUBMIT PAGE ══════════════ -->
      <div id="page-submit" class="page active space-y-4">

        <h2 class="text-lg font-bold text-slate-900">Submit a Product Review</h2>

        <!-- Your Details -->
        <fieldset class="fieldset">
          <legend class="legend">Your Details</legend>
          <label class="field-label">Your name</label>
          <input type="text" id="customerName" placeholder="e.g. Emma Byrne" class="field-input" />
        </fieldset>

        <!-- Product -->
        <fieldset class="fieldset">
          <legend class="legend">Product</legend>
          <label class="field-label">Product name</label>
          <input type="text" id="productName" placeholder="e.g. Nike Air Max" class="field-input" />
          <label class="field-label mt-3">Category</label>
          <select id="productCategory" class="field-input">
            <option value="">-- Select category --</option>
            <option value="footwear">Footwear</option>
            <option value="electronics">Electronics</option>
            <option value="clothing">Clothing</option>
            <option value="food">Food &amp; Drink</option>
            <option value="sports">Sports</option>
            <option value="homeware">Homeware</option>
            <option value="other">Other</option>
          </select>
        </fieldset>

        <!-- Your Review -->
        <fieldset class="fieldset">
          <legend class="legend">Your Review</legend>
          <label class="field-label">Star rating</label>
          <select id="starRating" class="field-input">
            <option value="5">★★★★★ (5)</option>
            <option value="4">★★★★☆ (4)</option>
            <option value="3">★★★☆☆ (3)</option>
            <option value="2">★★☆☆☆ (2)</option>
            <option value="1">★☆☆☆☆ (1)</option>
          </select>
          <label class="field-label mt-3">Review text</label>
          <textarea
            id="reviewText"
            rows="4"
            placeholder="Write your review here..."
            class="field-input resize-none"
          ></textarea>
        </fieldset>

        <!-- Product Image -->
        <fieldset class="fieldset">
          <legend class="legend">Product Image</legend>
          <label class="field-label">Upload a photo of the product</label>
          <input
            type="file"
            id="imageFile"
            accept="image/*"
            class="w-full text-sm text-slate-500
                   file:mr-3 file:rounded file:border file:border-slate-300
                   file:bg-slate-50 file:px-3 file:py-1
                   file:text-sm file:text-slate-700
                   hover:file:bg-slate-100 transition"
          />
          <img
            id="preview-img"
            alt="Preview"
            class="hidden mt-3 w-40 rounded border border-slate-200 object-cover"
          />
        </fieldset>

        <button id="btn-submit-review" class="btn-primary w-full">
          Submit Review
        </button>

        <p id="status-msg" class="min-h-5 text-center text-sm text-slate-500"></p>
      </div>

      <!-- ══════════════ GALLERY PAGE ══════════════ -->
      <div id="page-gallery" class="page space-y-5">

        <div class="flex items-center justify-between">
          <h2 class="text-lg font-bold text-slate-900">Browse Approved Reviews</h2>
          <button id="btn-load-gallery" class="btn-primary">Load Reviews</button>
        </div>

        <div class="flex items-center gap-3">
          <label class="text-sm font-medium text-slate-600">Filter by category</label>
          <select id="filter-category" class="field-input w-auto">
            <option value="">All categories</option>
            <option value="footwear">Footwear</option>
            <option value="electronics">Electronics</option>
            <option value="clothing">Clothing</option>
            <option value="food">Food &amp; Drink</option>
            <option value="sports">Sports</option>
            <option value="homeware">Homeware</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div id="gallery-results" class="space-y-4">
          <p class="text-sm text-slate-400">Click a category or load all reviews.</p>
        </div>
      </div>

      <!-- ══════════════ ADMIN PAGE ══════════════ -->
      <!--
      <div id="page-admin" class="page space-y-4">
        <h2 class="text-lg font-bold text-slate-900">Admin — All Submissions</h2>
        <p class="text-xs text-slate-400">Shows all reviews including rejected ones.</p>
        <button id="btn-load-admin" class="btn-primary">Load All Records</button>
        <div id="admin-results" class="space-y-3"></div>
      </div>
      -->

    </div>
  </div>
</Layout>

<style>
  /* If you’re just using the default theme with no customizations (e.g. by using things like @theme, @custom-variant, @plugin, etc…), you can import tailwindcss directly: */
  @reference "tailwindcss";
  
  /* ── Page visibility — toggled by JS ── */
  .page        { display: none; }
  .page.active { display: block; }

  /* ── Nav tabs ── */
  .nav-tab {
    @apply cursor-pointer border-b-2 border-transparent px-4 py-2
           text-sm font-medium text-slate-400 transition-colors
           hover:text-slate-700;
  }
  .nav-tab.active {
    @apply border-indigo-500 font-bold text-slate-900;
  }

  /* ── Fieldset — matches screenshot border-with-legend look ── */
  .fieldset {
    @apply rounded border border-slate-300 px-4 pb-5 pt-1;
  }

  /* ── Legend — bold label embedded in the fieldset border ── */
  .legend {
    @apply px-1 text-sm font-bold text-slate-900;
  }

  /* ── Form label ── */
  .field-label {
    @apply mb-1 block text-sm text-slate-700;
  }

  /* ── All text inputs, selects, textareas ── */
  .field-input {
    @apply w-full rounded border border-slate-300 bg-white px-3 py-2
           text-sm text-slate-900 placeholder-slate-400 transition
           focus:border-indigo-400 focus:outline-none focus:ring-1 focus:ring-indigo-400;
  }

  /* ── Primary button — matches screenshot plain grey button ── */
  .btn-primary {
    @apply rounded border border-slate-300 bg-slate-100 px-4 py-2
           text-sm font-medium text-slate-800 shadow-sm transition-colors
           hover:bg-slate-200;
  }
</style>

